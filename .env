# LLM WIKI — Environment Variables
# Copy to .env and fill in values

# Git API (choose one)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GIT_REMOTE_URL=https://github.com/your-org/llm-wiki.git

# OpenAI (for vector embeddings in F3)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Server
PORT=3000
NODE_ENV=development

# Paths
MODULES_DIR=./modules
DOCS_DIR=./docs
SYSTEM_DIR=./.system
NOTES_DIR=./.system/user/notes
