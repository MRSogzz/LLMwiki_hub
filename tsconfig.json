{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "lib":              ["ES2022"],
    "outDir":           "./dist",
    "rootDir":          "./",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule":true,
    "declaration":      true,
    "sourceMap":        true,
    "allowImportingTsExtensions": true,
    "noEmit":           true
  },
  "ts-node": {
    "esm":            true,
    "experimentalSpecifierResolution": "node"
  },
  "include": ["backend/**/*.ts", "modules/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
