{
  "name": "llm-wiki",
  "version": "1.0.0",
  "description": "人機協作知識管理系統 — Markdown SSOT + HUD 介面 + 代碼 I/O 週期表",
  "license": "GPL-3.0",
  "author": "LLM WIKI Contributors",
  "private": true,
  "type": "module",
  "bin": {
    "wiki": "./cli/wiki.ts"
  },
  "scripts": {
    "dev":          "node --loader ts-node/esm backend/server.ts",
    "build":        "tsc --project tsconfig.json",
    "start":        "node dist/backend/server.js",
    "parse":        "node --loader ts-node/esm backend/parser/metadata-parser.ts",
    "validate":     "node --loader ts-node/esm backend/type-checker/type-checker.ts",
    "ci-writeback": "node --loader ts-node/esm backend/ci-watcher/ci-watcher.ts",
    "vector:build": "node --loader ts-node/esm backend/vector/vector-index.ts",
    "type-check":   "tsc --noEmit",
    "wiki":         "node --loader ts-node/esm cli/wiki.ts",
    "wiki:note":    "node --loader ts-node/esm cli/wiki.ts note",
    "wiki:git":     "node --loader ts-node/esm cli/wiki.ts git",
    "wiki:test":    "node --loader ts-node/esm cli/wiki.ts test",
    "wiki:module":  "node --loader ts-node/esm cli/wiki.ts module",
    "wiki:doc":     "node --loader ts-node/esm cli/wiki.ts doc",
    "wiki:map":     "node --loader ts-node/esm cli/wiki.ts map",
    "wiki:milestone":"node --loader ts-node/esm cli/wiki.ts milestone",
    "wiki:vector":  "node --loader ts-node/esm cli/wiki.ts vector",
    "wiki:ci":      "node --loader ts-node/esm cli/wiki.ts ci"
  },
  "dependencies": {
    "chokidar":    "^3.6.0",
    "express":     "^4.19.2",
    "gray-matter": "^4.0.3",
    "cors":        "^2.8.5",
    "simple-git":  "^3.25.0",
    "remark":      "^15.0.1",
    "remark-parse":"^11.0.0",
    "unified":     "^11.0.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors":    "^2.8.17",
    "@types/node":    "^20.14.0",
    "typescript":     "^5.4.5",
    "ts-node":        "^10.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
